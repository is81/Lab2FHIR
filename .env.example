# Lab2FHIR 环境变量配置
# 复制此文件为 .env 并按需修改

# 环境: development | production
LAB2FHIR_ENV=development

# 数据库路径 (默认自动检测，通常无需修改)
# DATABASE_URL=sqlite:///backend/lab2fhir.db

# 上传目录 (默认自动检测)
# LAB2FHIR_UPLOAD_DIR=backend/src/uploads

# PDF 测试文件目录 (默认自动检测)
# LAB2FHIR_PDF_TEST_DIR=docs/pdf_test

# 上传文件大小限制 (默认 50MB)
# LAB2FHIR_MAX_FILE_SIZE=52428800

# CORS 允许的来源 (逗号分隔, development 默认 *)
# CORS_ORIGINS=http://localhost:5173

# Stats 缓存时间 (秒)
# LAB2FHIR_STATS_CACHE_TTL=300

# 日志级别: DEBUG | INFO | WARNING | ERROR
# LAB2FHIR_LOG_LEVEL=INFO

# JWT 认证（生产环境必填！）
# LAB2FHIR_JWT_SECRET=$(openssl rand -hex 32)
# LAB2FHIR_JWT_EXPIRE_HOURS=48

# 初始管理员密码（不设置则随机生成）
# LAB2FHIR_ADMIN_PASSWORD=your-admin-password
# LAB2FHIR_DOCTOR_PASSWORD=your-doctor-password
